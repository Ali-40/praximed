# PraxisMed — frontend environment configuration
# local development only — copy to frontend/.env.local for local work
# NEXT_PUBLIC_* variables are exposed to the browser — do not put secrets here

# Backend API base URL — public build variable, not a secret
# Production: set to your stable HTTPS backend URL (e.g. https://api.praxismed.example.com)
# Staging: set to your staging HTTPS backend URL
# Local: falls back to http://127.0.0.1:8000 if not set
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
