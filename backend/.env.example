# PraxisMed — local development environment configuration
# local development only — never commit real production secrets to version control
# copy to backend/.env for local work: cp backend/.env.example backend/.env

# Database — matches docker-compose.postgres.yml defaults
DATABASE_URL=postgresql://praxismed:praxismed_local_password@localhost:5433/praxismed_local
POSTGRES_DB=praxismed_local
POSTGRES_USER=praxismed
POSTGRES_PASSWORD=praxismed_local_password

# Application
APP_ENV=local
API_HOST=127.0.0.1
API_PORT=8000

# JWT authentication — change before any non-local deployment
JWT_SECRET_KEY=local-dev-jwt-secret-key-change-in-production

# Webhook HMAC secrets — must match the values configured in the Vapi and n8n dashboards
VAPI_WEBHOOK_SECRET=local-vapi-secret-change-me
N8N_WEBHOOK_SECRET=local-n8n-secret-change-me
INTERNAL_WEBHOOK_SECRET=local-internal-secret-change-me

# CORS — comma-separated list of allowed frontend origins; defaults to localhost:3000 if unset
# FRONTEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
